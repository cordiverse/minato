{
  "name": "@root/minato",
  "private": true,
  "packageManager": "yarn@4.13.0",
  "type": "module",
  "version": "1.0.0",
  "main": "index.js",
  "workspaces": [
    "docs",
    "external/*",
    "packages/*"
  ],
  "license": "MIT",
  "scripts": {
    "build": "yakumo esbuild & yakumo tsc",
    "lint": "eslint packages --ext=ts --cache",
    "test": "yakumo mocha --import tsx --import yml-register -t 10000",
    "test:text": "shx rm -rf coverage && c8 -r text yarn test",
    "test:json": "shx rm -rf coverage && c8 -r json yarn test",
    "test:html": "shx rm -rf coverage && c8 -r html yarn test"
  },
  "devDependencies": {
    "@cordisjs/eslint-config": "^1.1.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.3.5",
    "c8": "^10.1.3",
    "esbuild": "^0.27.3",
    "eslint": "^8.57.1",
    "eslint-plugin-mocha": "^10.5.0",
    "mocha": "^11.7.5",
    "shx": "^0.4.0",
    "tsx": "npm:@cordiverse/tsx@4.19.3-fix.3",
    "typescript": "^5.9.3",
    "yakumo": "^3.1.0",
    "yakumo-esbuild": "^3.0.1",
    "yakumo-mocha": "^3.0.3",
    "yakumo-tsc": "^3.0.1",
    "yml-register": "^1.2.5"
  }
}
